#!/bin/bash
# Claude Monitor — SketchyBar Plugin Config
# Install: brew tap FelixKratz/formulae && brew install sketchybar
# Copy to: ~/.config/sketchybar/

PLUGIN_DIR="$HOME/claude-monitor/sketchybar/plugins"
FONT="SF Mono"

# Bar appearance
sketchybar --bar \
  height=28 \
  position=top \
  padding_left=8 \
  padding_right=8 \
  color=0xff1a1a1a \
  border_color=0xff333333 \
  border_width=1 \
  y_offset=0 \
  shadow=on

# Default item settings
sketchybar --default \
  icon.font="$FONT:Bold:13.0" \
  icon.color=0xffff9500 \
  label.font="$FONT:Regular:12.0" \
  label.color=0xffcccccc \
  padding_left=4 \
  padding_right=4

# ── Claude Status (left) ──
sketchybar --add item claude left \
  --set claude \
    icon="\uf120" \
    label="CC: ..." \
    update_freq=3 \
    script="$PLUGIN_DIR/claude_status.sh"

# ── Cost Tracker (left) ──
sketchybar --add item costs left \
  --set costs \
    icon="\uf155" \
    label="$0" \
    update_freq=30 \
    script="$PLUGIN_DIR/costs.sh"

# ── Network (left) ──
sketchybar --add item network left \
  --set network \
    icon="\uf0c1" \
    label="..." \
    update_freq=10 \
    script="$PLUGIN_DIR/network.sh"

# ── SSH Tunnels (left) ──
sketchybar --add item tunnels left \
  --set tunnels \
    icon="\uf023" \
    label="..." \
    update_freq=15 \
    script="$PLUGIN_DIR/tunnels.sh"

# ── Qdrant (right) ──
sketchybar --add item qdrant right \
  --set qdrant \
    icon="\uf1c0" \
    label="..." \
    update_freq=30 \
    script="$PLUGIN_DIR/qdrant.sh"

# Subscribe to events
sketchybar --add event claude_refresh
sketchybar --subscribe claude claude_refresh
